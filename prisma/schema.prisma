generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Content {
  id          String   @id @default(cuid())
  userId      String
  contentType String
  tone        String
  length      String
  topic       String
  result      String
  keywords    String[] @default([])
  audience    String?
  createdAt   DateTime @default(now())
}